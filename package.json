{
  "name": "macplants-erp-spec",
  "private": true,
  "version": "1.0.0",
  "description": "Living specification for the MacPlants ERP build, served via Vite + React (with Docsify legacy fallback during transition).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config app/vite.config.js",
    "build": "vite build --config app/vite.config.js",
    "preview": "vite preview --config app/vite.config.js",
    "dev:docsify": "npx docsify-cli@4 serve .",
    "update-spec": "node scripts/update-spec.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "dotenv": "^16.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0"
  }
}
