{
  "name": "macplants-erp-spec",
  "private": true,
  "version": "1.0.0",
  "description": "Living specification for the MacPlants ERP build, served via Vite + React.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/build-manifest.mjs && node scripts/build-search-index.mjs && node scripts/build-schema-index.mjs && node scripts/build-component-map-index.mjs",
    "dev": "vite --config app/vite.config.js",
    "prebuild": "node scripts/build-manifest.mjs && node scripts/build-search-index.mjs && node scripts/build-schema-index.mjs && node scripts/build-component-map-index.mjs",
    "build": "vite build --config app/vite.config.js",
    "preview": "vite preview --config app/vite.config.js",
    "build-manifest": "node scripts/build-manifest.mjs",
    "build-search-index": "node scripts/build-search-index.mjs",
    "build-schema-index": "node scripts/build-schema-index.mjs",
    "build-component-map-index": "node scripts/build-component-map-index.mjs",
    "md-copy": "node scripts/md-to-clipboard.mjs",
    "update-spec": "node scripts/update-spec.mjs",
    "pull-gdrive-doc": "node scripts/pull-doc.mjs",
    "test": "node --test app/src/components/*.test.js scripts/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "dotenv": "^16.4.5",
    "marked": "^18.0.3",
    "mermaid": "^10.9.5",
    "minisearch": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "github-slugger": "^2.0.0",
    "vite": "^5.4.0"
  }
}
